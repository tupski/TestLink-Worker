{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": "*.html"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/(.*)", "destination": "/$1" }
  ]
}
