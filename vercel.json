{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": [
        "*.html",
        "css/**",
        "js/**",
        "icons/**",
        "manifest.webmanifest",
        "sw.js",
        "data/**"
      ]
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/about", "destination": "/about.html" }
  ]
}
